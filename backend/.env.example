# Use transient mode for the fast demo experience without any external DB.
ROUTEFUSION_TRANSIENT_MODE=true

# Optional: disable transient mode and point RouteFusion to PostgreSQL when
# you explicitly want persistent storage.
# DATABASE_URL=postgresql+psycopg://user:password@host:5432/postgres?sslmode=require
JWT_SECRET=routefusion-demo-secret
JWT_ACCESS_EXP_MINUTES=30
JWT_REFRESH_EXP_DAYS=14
CORS_ORIGINS=http://localhost:5173
